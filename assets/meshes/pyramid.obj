# Pyramid (square base) with UVs. CCW winding (outward).
# Base at y=-1, apex at y=1.

v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0 -1.0  1.0
v -1.0 -1.0  1.0
v  0.0  1.0  0.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vt 0.5 1.0

# Base (faces downward, CCW when viewed from below)
f 1/1 2/2 3/3
f 1/1 3/3 4/4

# Sides (CCW outward)
f 1/1 5/5 2/2
f 2/1 5/5 3/2
f 3/1 5/5 4/2
f 4/1 5/5 1/2
