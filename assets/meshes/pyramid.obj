# Pyramid (square base) with UVs. CCW winding (outward).
# Base at y=-1, apex at y=1.
# These meshes are generated by LLM (Codex).

# --- Positions (v) ---
v -1.0 -1.0 -1.0  # 1: Bottom Front Left
v  1.0 -1.0 -1.0  # 2: Bottom Front Right
v  1.0 -1.0  1.0  # 3: Bottom Back Right
v -1.0 -1.0  1.0  # 4: Bottom Back Left
v  0.0  1.0  0.0  # 5: Apex (Top)

# --- UV Coordinates (vt) ---
vt 0.0 0.0  # 1: Bottom Left
vt 1.0 0.0  # 2: Bottom Right
vt 1.0 1.0  # 3: Top Right
vt 0.0 1.0  # 4: Top Left
vt 0.5 1.0  # 5: Apex center (for sides)

# --- Normals (vn) ---
vn  0.0 -1.0  0.0   # 1: Down (Base)
vn  0.0  0.447 -0.894 # 2: Front Face
vn  0.894  0.447  0.0 # 3: Right Face
vn  0.0  0.447  0.894 # 4: Back Face
vn -0.894  0.447  0.0 # 5: Left Face

# --- Faces (f Pos/UV/Normal) ---
# Base (Square split into two triangles)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# Front Side
f 1/1/2 5/5/2 2/2/2

# Right Side
f 2/1/3 5/5/3 3/3/3

# Back Side
f 3/1/4 5/5/4 4/4/4

# Left Side
f 4/1/5 5/5/5 1/2/5